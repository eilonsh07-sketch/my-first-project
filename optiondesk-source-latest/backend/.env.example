# Copy this file to .env and fill in your values.
# The .env file is gitignored and must NEVER be committed.

# Required: access gate code shown to users at login. Use a strong random value.
ACCESS_CODE=your-strong-access-code-here

# Required for production: comma-separated list of allowed frontend origins.
# Example: https://optiondesk.vercel.app
# Leave blank for local dev (defaults to localhost:5173 / localhost:3000).
ALLOWED_ORIGINS=

# Optional: Anthropic API key — enables Hebrew company summaries via Claude.
ANTHROPIC_API_KEY=

# Optional: Polygon.io API key — enables REAL historical options data for backtesting.
# Plan required: Options ($79/month) → https://polygon.io/dashboard/api-keys
# Without this key the system uses synthetic Black-Scholes pricing (free, less accurate).
POLYGON_API_KEY=

# Optional: PostgreSQL database URL — enables persistent watchlist.
# Leave blank to use ephemeral SQLite.
DATABASE_URL=
